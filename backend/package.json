{
  "name": "saas-confeitaria-backend",
  "version": "2.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/core/server.ts",
    "build": "tsc",
    "start": "node dist/core/server.js",
    "seed": "ts-node-dev --transpile-only src/database/seed.ts",
    "migrate": "ts-node-dev --transpile-only -e 'require(\"./src/database/migrate\").runMigrations().then(()=>process.exit(0))'"
  },
 "dependencies": {
  "@fastify/cors": "^8.5.0",
  "@fastify/jwt": "^10.0.0",
  "@fastify/rate-limit": "^9.1.0",
  "bcrypt": "^5.1.1",
  "dotenv": "^16.6.1",
  "fastify": "^4.29.1",
  "jsonwebtoken": "^9.0.3",
  "mysql2": "^3.11.0",
  "pino-pretty": "^11.3.0",
  "zod": "^3.23.8"
},
"devDependencies": {
  "@types/bcrypt": "^5.0.2",
  "@types/jsonwebtoken": "^9.0.10",
  "@types/node": "^20.19.37",
  "ts-node-dev": "^2.0.0",
  "typescript": "^5.4.5"
}
}
